{
  "manifest_version": 3,
  "name": "Sight-Assist",
  "version": "2.8",
  "description": "Abre un menú que permite modificar la visualización web de 6 formas diferentes, facilitando la lectura de una pagina independientemente de la discapacidad visual del usuario.",

  "icons": {
    "96": "SightAssist-Icono.png"
  },

  "permissions": ["scripting", "activeTab", "storage"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-polyfill.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  
  "action": {
    "default_popup": "SightAssist.html",
    "default_icon": {
      "96": "SightAssist-Icono.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"],
    "type": "module"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "Sight-Assist@addon",
      "strict_min_version": "109.0",
      "data_collection_permissions":{
        "required": ["none"],
        "optional": []
      }
    }
  }
}
